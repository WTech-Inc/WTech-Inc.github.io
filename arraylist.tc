// ==========================================
// ArrayList 資料結構
// 動態陣列，支援自動擴容
// ==========================================

// 配置設定
set DEFAULT_CAPACITY -> 10;
set MAX_CAPACITY -> 100;

// ArrayList 狀態
set list_size -> 0;
set list_capacity -> 0;

// 數據存儲 (支援最多 100 個元素)
set a0 -> 0; set a1 -> 0; set a2 -> 0; set a3 -> 0; set a4 -> 0;
set a5 -> 0; set a6 -> 0; set a7 -> 0; set a8 -> 0; set a9 -> 0;
set a10 -> 0; set a11 -> 0; set a12 -> 0; set a13 -> 0; set a14 -> 0;
set a15 -> 0; set a16 -> 0; set a17 -> 0; set a18 -> 0; set a19 -> 0;
set a20 -> 0; set a21 -> 0; set a22 -> 0; set a23 -> 0; set a24 -> 0;
